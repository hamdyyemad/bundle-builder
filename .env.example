# Local dev points at the docker-compose Postgres (host port 5433 to avoid
# colliding with a locally installed Postgres on 5432).
DATABASE_URL="postgresql://bundle:bundle@localhost:5433/bundle_builder?schema=public"

# Shared secret for POST /api/revalidate, which busts the cached catalog after
# an edit. Generate with: openssl rand -hex 32
REVALIDATE_SECRET=""

# Absolute origin used for server-side fetches to the app's own API routes.
# Optional locally (falls back to http://127.0.0.1:$PORT) and on Vercel (uses
# VERCEL_URL). Set it explicitly behind a proxy or custom domain.
# APP_URL="https://your-domain.com"
